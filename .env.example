# Required: Get a free token at https://ion.cesium.com/signup
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Optional: Enables Google Photorealistic 3D Tiles
# Enable Map Tiles API at https://console.cloud.google.com/apis/library/tile.googleapis.com
VITE_GOOGLE_MAPS_KEY=

# Optional: Enables AI chat (Claude)
# Get an API key at https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=
