# All keys are optional. The app works out of the box with an embedded Cesium Ion token.
# Override here or via the command bar ("set cesium token ...", "set key sk-...").

# Override the default Cesium Ion token (free at https://ion.cesium.com/signup)
VITE_CESIUM_ION_TOKEN=

# Enable AI chat with Claude (get a key at https://console.anthropic.com/)
VITE_ANTHROPIC_API_KEY=
